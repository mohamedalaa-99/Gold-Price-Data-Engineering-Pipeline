$'\n        when currency_name = 'EGP' then 'E\u00a3'\n        else 'Symbol'\n    end as symbol\nfrom currency_raw\nwhere currency_name is not null", "relation_name": "`databricks_workspace`.`gold_layer`.`dim_currency`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-28T23:59:53.213252Z", "completed_at": "2026-06-28T23:59:53.225249Z"}, {"name": "execute", "started_at": "2026-06-28T23:59:53.226388Z", "completed_at": "2026-06-28T23:59:55.643698Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 2.571564197540283, "adapter_response": {"_message": "OK", "query_id": "01f1734d-7518-1498-a8a1-cb77c96be841"}, "message": "OK", "failures": null, "unique_id": "model.gold_price_dbt.dim_date", "compiled": true, "compiled_code": "\n\nwith date_raw as (\n    select distinct event_date as full_date\n    from `databricks_workspace`.`gold_layer`.`stg_gold_price` \n)\n\nselect\n    cast(date_format(full_date, 'yyyyMMdd') as int) as date_id,\n    full_date,\n    day(full_date) as day,\n    month(full_date) as month,\n    year(full_date) as year\nfrom date_raw\nwhere full_date is not null", "relation_name": "`databricks_workspace`.`gold_layer`.`dim_date`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-28T23:59:55.792852Z", "completed_at": "2026-06-28T23:59:55.807434Z"}, {"name": "execute", "started_at": "2026-06-28T23:59:55.808723Z", "completed_at": "2026-06-28T23:59:58.218033Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 2.576111316680908, "adapter_response": {"_message": "OK", "query_id": "01f1734d-76a0-18d5-9ed5-309b5b061ae9"}, "message": "OK", "failures": null, "unique_id": "model.gold_price_dbt.dim_time", "compiled": true, "compiled_code": "\n\nwith time_raw as (\n    select distinct ingestion_timestamp as full_time\n    from `databricks_workspace`.`gold_layer`.`stg_gold_price`\n)\n\nselect\n    cast(date_format(full_time, 'HHmmss') as int) as time_id,\n    hour(full_time) as hour,\n    minute(full_time) as minute,\n    second(full_time) as second,\n    date_format(full_time, 'HH:mm:ss') as full_time\nfrom time_raw\nwhere full_time is not null", "relation_name": "`databricks_workspace`.`gold_layer`.`dim_time`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-28T23:59:58.376362Z", "completed_at": "2026-06-28T23:59:58.397085Z"}, {"name": "execute", "started_at": "2026-06-28T23:59:58.398803Z", "completed_at": "2026-06-29T00:00:02.190033Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 3.978386878967285, "adapter_response": {"_message": "OK", "query_id": "01f1734d-782f-1ca5-b924-c042c59d1de7"}, "message": "OK", "failures": null, "unique_id": "model.gold_price_dbt.fact_gold_price", "compiled": true, "compiled_code": "\n\nwith stg_data as (\n    select * from `databricks_workspace`.`gold_layer`.`stg_gold_price`\n),\n\ndim_date as (\n    select * from `databricks_workspace`.`gold_layer`.`dim_date`\n),\n\ndim_time as (\n    select * from `databricks_workspace`.`gold_layer`.`dim_time`\n),\n\ndim_currency as (\n    select * from `databricks_workspace`.`gold_layer`.`dim_currency`\n)\n\nselect\n    d.date_id,\n    t.time_id,\n    c.currency_id,\n    s.price_usd as price,\n    1.0 as exchangeRate \nfrom stg_data s\nleft join dim_date d on s.event_date = d.full_date\nleft join dim_time t on hour(s.ingestion_timestamp) = t.hour \n                     and minute(s.ingestion_timestamp) = t.minute \n                     and second(s.ingestion_timestamp) = t.second\nleft join dim_currency c on s.currency = c.currency_name", "relation_name": "`databricks_workspace`.`gold_layer`.`fact_gold_price`", "batch_results": null}], "elapsed_time": 17.581259727478027, "args": {"require_unique_project_resource_names": false, "cache_selected_only": false, "defer": false, "project_dir": "/opt/airflow/gold_price_dbt", "require_resource_names_without_spaces": true, "source_freshness_run_project_ho